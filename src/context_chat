2. Подключите ID в хук useSuiFundDashboard

Ваш компонент PortfolioPage.tsx использует этот хук для получения данных. Настройте его на чтение объекта Basket:
TypeScript

// src/hooks/useSuiFundDashboard.ts
import { useSuiClientQuery } from '@mysten/dapp-kit';
import { AV8_BASKET_ID } from '../lib/suiFund';

export function useSuiFundDashboard() {
  // Запрос данных объекта из сети Sui
  const { data, loading, error } = useSuiClientQuery('getObject', {
    id: AV8_BASKET_ID,
    options: {
      showContent: true, // Чтобы увидеть внутренние поля (assets, total_shares)
    },
  });

  // Логика трансформации данных из Sui в формат для графиков Recharts
  const formattedData = React.useMemo(() => {
    if (!data?.data?.content) return fallbackData;
    
    // Здесь вы парсите data.data.content.fields
    // и возвращаете объект для вашего PortfolioPage
    return transformSuiDataToDashboard(data.data.content);
  }, [data]);

  return {
    data: formattedData,
    isLoading: loading,
    isError: !!error,
  };
}

3. Настройка динамических данных в PortfolioPage.tsx

В вашем коде PortfolioPage.tsx уже есть переменная isUsingFallbackData. После вставки реальных ID она автоматически должна переключиться (или вы можете сделать это вручную):
TypeScript

// Внутри компонента PortfolioPage
const { data: dashboardData, isLoading } = useSuiFundDashboard();

// Если данные загружены из чейна, используем их
const isUsingFallbackData = !dashboardData && !isLoading;

