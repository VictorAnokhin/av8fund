# ═══════════════════════════════════════════════════════════
# Production Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.production on your server
# Update all values to match your production environment

# API origin for browser fetch() — MUST be present at `vite build` time (this file is NOT read by the static server).
# If you ship only `dist/`, either rebuild with this set, or inject <meta name="av8fund-api-base-url" content="https://…" /> in index.html on the server.
# Use the public URL of Laravel (where /api/... returns JSON). Same host as SPA is OK if nginx proxies /api to PHP.
# Example (autoagent): VITE_API_BASE_URL=https://app.autoagent.in.ua
VITE_API_BASE_URL=https://av8capital.space

# IMAGE базовый URL для картинок
# Production: your CDN or domain URL
VITE_IMAGE_BASE_URL=https://sklad.autoagent.in.ua

# Цель для Vite dev proxy (/api, /sanctum) при `npm run dev`
# Для production-сборки и runtime браузера не используется
VITE_API_PROXY_TARGET=https://av8capital.space

# API FID (firma ID) - идентификатор фирмы для запросов к API
# Default: 2, change to match your Laravel API requirements
VITE_API_FID=12

# Google OAuth Client ID for Google Sign-In fallback on frontend
VITE_GOOGLE_CLIENT_ID=257444416119-nk4t6eq0aeh31c1ho18e6huivutthrgp.apps.googleusercontent.com
VITE_SUI_GOOGLE_CLIENT_ID=257444416119-nk4t6eq0aeh31c1ho18e6huivutthrgp.apps.googleusercontent.com

VITE_WEB3AUTH_CLIENT_ID=BB3EREvKBaT2bo2BaX0p1MHcSji1poA9LFf_c_pgsECdOJBy_LglrY1C4_Jr0txIvALjsduNqu0aNdKEaiOyW3c
